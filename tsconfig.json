{
  // Type-checks the LOGIC layer (lib, hooks, API proxy, shared data) via
  // JSDoc-aware checkJs — no migration, no emit, no runtime change. The JSX
  // component layer is deliberately out of scope: its safety is covered by
  // the 127-test suite driving the real <App/>, and checking JSX without
  // converting to TSX drowns real signal in prop-shape noise.
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    // FULL strict — including noImplicitAny: every parameter and collection in
    // the logic layer carries an explicit JSDoc type, so null-safety, correct
    // comparisons AND untyped-input mistakes are all compile errors.
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/lib/**/*.js",
    "src/hooks/**/*.js",
    "src/data.js",
    "api/**/*.js"
  ]
}
